@EndUserText.label: 'Acess Control - Literal'
@MappingRole: true
define role ZAC_01_LOG_C403 {
    grant
        select
            on
                ZCDS_30_LOG_C403
                    where
                        CountryCode = 'ES';
                        
    grant select on ZCDS_31_LOG_C403
      where Status = 'N';                    
                        
}