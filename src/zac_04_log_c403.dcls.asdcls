@EndUserText.label: 'Acess Control - Aspect PFCG'
@MappingRole: true
define role ZAC_04_LOG_C403 {
    grant 
        select
            on
                ZCDS_33_LOG_C403
                    where
                        (CarrierId) = aspect pfcg_auth(ZAOCARR403, ZAFCARR403, ACTVT = '03');
                        
}